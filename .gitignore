#ward program root .gitignore
# ── Secrets — NEVER commit ────────────────────────────────────────────────
.env
**/.env.*
**/.env
**/.env.local
**/.env.*.local

# ── Node modules ──────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build output ──────────────────────────────────────────────────────────
dist/
build/
**/dist/
**/build/

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
**/npm-debug.log*

# ── OS / IDE ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Scratch / temp files ──────────────────────────────────────────────────
*.txt

# ── NOTE: *.sql is intentionally NOT excluded ─────────────────────────────
# Your database scripts in the db/ subfolder should be version controlled.