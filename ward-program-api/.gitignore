#api gignore file for ward-program-api
# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.env
.env.*

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── IDE / Editor settings ─────────────────────────────────────────────────────
.vscode/
.idea/

# ── Dev artifacts ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
nodemon.json

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.txt